# GitHub Copilot authentication for LLM scoring
# Option A: set a PAT with Copilot scope
GITHUB_PAT=ghp_...
# Option B: use `gh auth login` and keep this unset

# France Travail API credentials - https://francetravail.io/data/api
# Souscrire aux APIs: "ROME - Métiers v1" et "Offres d'emploi v2"
FRANCE_TRAVAIL_CLIENT_ID=PAR_...
FRANCE_TRAVAIL_CLIENT_SECRET=...
